# Skill-Anything LLM Configuration
# Powers quiz generation, flashcard creation, knowledge extraction, and more.

# LLM API Key (required for high-quality generation)
SKILL_ANYTHING_API_KEY=sk-your-api-key-here

# LLM API Base URL (OpenAI-compatible endpoint)
SKILL_ANYTHING_API_BASE=https://api.openai.com/v1

# Chat model (used for all text generation)
SKILL_ANYTHING_MODEL=gpt-5.4

# Image generation API (used for visual concept maps)
# Can be the same base or a separate endpoint
SKILL_ANYTHING_IMAGE_API_BASE=https://api.openai.com/v1
SKILL_ANYTHING_IMAGE_MODEL=dall-e-3

# HTTP Proxy (optional)
# SKILL_ANYTHING_PROXY=http://127.0.0.1:7890
